# ==============================================================================
# UroSense Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application
# ------------------------------------------------------------------------------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# Supabase (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Server-side only — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# ------------------------------------------------------------------------------
# OpenAI (for AI report generation)
# Get from: https://platform.openai.com/api-keys
# ------------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# ------------------------------------------------------------------------------
# Telemetry Ingestion (ESP32 devices)
# ------------------------------------------------------------------------------
TELEMETRY_INGEST_API_KEY="your-secure-device-api-key"

# ------------------------------------------------------------------------------
# Notification Services (optional for development)
# ------------------------------------------------------------------------------
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_SENDER_NUMBER="+1234567890"

# ------------------------------------------------------------------------------
# Monitoring (optional for development)
# ------------------------------------------------------------------------------
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# ------------------------------------------------------------------------------
# Deployment (set automatically by Vercel)
# ------------------------------------------------------------------------------
# VERCEL_URL is set automatically, do not set manually
