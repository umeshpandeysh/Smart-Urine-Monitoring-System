# UroSense Platform — .gitignore
# Extends the original hardware/firmware gitignore

# ================================
# Next.js
# ================================
.next/
out/
build/
dist/

# ================================
# Dependencies
# ================================
node_modules/
.pnp
.pnp.js

# ================================
# Environment Variables (CRITICAL)
# ================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ================================
# Supabase
# ================================
.supabase/
supabase/.temp/

# ================================
# Testing
# ================================
coverage/
playwright-report/
test-results/
.vitest-cache/

# ================================
# TypeScript
# ================================
*.tsbuildinfo
next-env.d.ts

# ================================
# Logs
# ================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ================================
# OS
# ================================
.DS_Store
Thumbs.db
*.swp
*.swo

# ================================
# Editor
# ================================
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ================================
# Hardware / Firmware Artifacts
# ================================
*.elf
*.hex
*.bin
*.map
*.o
*.a
.pio/
.pioenvs/

# ================================
# PDF Artifacts (generated)
# ================================
public/reports/*.pdf

# ================================
# Misc
# ================================
.vercel
*.pem

.vercel
